{
  "name": "gabon-gouv",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.2.17",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:once": "turbo test:once",
    "dev:citizen": "turbo dev --filter=citizen-web",
    "dev:admin": "turbo dev --filter=admin-web",
    "dev:platform": "turbo dev --filter=platform-web",
    "dev:convex": "bunx convex dev --cwd packages/backend"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
